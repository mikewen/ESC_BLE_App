<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#070D1A">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp">

        <!-- Title bar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="SENSOR CALIBRATION"
                android:textColor="#14FFEC" android:textSize="16sp" android:textStyle="bold"
                android:fontFamily="monospace"/>
            <Button android:id="@+id/btnBack"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="← BACK" android:textSize="12sp"
                android:backgroundTint="#1A2030" android:textColor="#88AABBCC"
                style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>

        <!-- ── BLE Connection ── -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#080F1E" app:cardCornerRadius="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="SENSOR DEVICE"
                        android:textColor="#14FFEC" android:textSize="13sp"
                        android:textStyle="bold" android:fontFamily="monospace"/>
                    <Button android:id="@+id/btnBleScan"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="SCAN" android:textSize="12sp" android:textStyle="bold"
                        android:backgroundTint="#0D3A2A" android:textColor="#14FFEC"
                        style="@style/Widget.MaterialComponents.Button"/>
                </LinearLayout>

                <TextView android:id="@+id/tvBleStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Tap SCAN to connect sensor"
                    android:textColor="#88CCFF" android:textSize="12sp"
                    android:fontFamily="monospace"/>

                <!-- Scan results — hidden until scan starts -->
                <TextView android:id="@+id/tvScanResults"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:textColor="#55AABBCC"
                    android:textSize="11sp" android:fontFamily="monospace"
                    android:layout_marginTop="4dp" android:visibility="gone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── MMC5603 Magnetometer Calibration ── -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#080F1E" app:cardCornerRadius="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="MMC5603 MAGNETOMETER" android:textColor="#14FFEC"
                    android:textSize="13sp" android:textStyle="bold"
                    android:fontFamily="monospace" android:layout_marginBottom="4dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Rotate boat slowly 360° in calm water at the dock."
                    android:textColor="#88AABBCC" android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <ProgressBar android:id="@+id/progressMagCal"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="18dp"
                    android:max="100" android:progress="0"
                    android:progressTint="#14FFEC" android:progressBackgroundTint="#1A2E4A"
                    android:layout_marginBottom="8dp"/>

                <TextView android:id="@+id/tvMagCalStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Connect sensor then tap START"
                    android:textColor="#88CCFF" android:textSize="12sp"
                    android:fontFamily="monospace" android:layout_marginBottom="4dp"/>

                <TextView android:id="@+id/tvMagCalSaved"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Not calibrated"
                    android:textColor="#55AABBCC" android:textSize="11sp"
                    android:fontFamily="monospace" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btnMagCalStart"
                        android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:text="▶ START"
                        android:textSize="13sp" android:textStyle="bold"
                        android:backgroundTint="#0D3A2A" android:textColor="#14FFEC"
                        android:layout_marginEnd="6dp"
                        style="@style/Widget.MaterialComponents.Button"/>
                    <Button android:id="@+id/btnMagCalFinish"
                        android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:text="✓ DONE"
                        android:textSize="13sp" android:textStyle="bold"
                        android:backgroundTint="#1A3A2A" android:textColor="#88FFCC88"
                        android:layout_marginEnd="6dp"
                        style="@style/Widget.MaterialComponents.Button"/>
                    <Button android:id="@+id/btnMagCalClear"
                        android:layout_width="wrap_content" android:layout_height="44dp"
                        android:text="CLR" android:textSize="11sp"
                        android:backgroundTint="#1A0A0A" android:textColor="#884444"
                        style="@style/Widget.MaterialComponents.Button"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── QMI8658C Gyro Bias Calibration ── -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#080F1E" app:cardCornerRadius="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="QMI8658C GYRO BIAS" android:textColor="#FFB300"
                    android:textSize="13sp" android:textStyle="bold"
                    android:fontFamily="monospace" android:layout_marginBottom="4dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Place sensor on a level surface and hold still for 5 seconds."
                    android:textColor="#88AABBCC" android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <TextView android:id="@+id/tvGyroCalStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Connect sensor then tap START"
                    android:textColor="#FFB300" android:textSize="12sp"
                    android:fontFamily="monospace" android:layout_marginBottom="4dp"/>

                <TextView android:id="@+id/tvGyroCalSaved"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Not calibrated"
                    android:textColor="#55AABBCC" android:textSize="11sp"
                    android:fontFamily="monospace" android:layout_marginBottom="4dp"/>

                <TextView android:id="@+id/tvGyroRotateDeg"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Rotate: 0.0°"
                    android:textColor="#FFB300" android:textSize="36sp"
                    android:textStyle="bold" android:fontFamily="monospace"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btnGyroCalStart"
                        android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:text="▶ START (5s)"
                        android:textSize="13sp" android:textStyle="bold"
                        android:backgroundTint="#2A2000" android:textColor="#FFB300"
                        android:layout_marginEnd="6dp"
                        style="@style/Widget.MaterialComponents.Button"/>
                    <Button android:id="@+id/btnGyroCalClear"
                        android:layout_width="wrap_content" android:layout_height="44dp"
                        android:text="CLR" android:textSize="11sp"
                        android:backgroundTint="#1A0A0A" android:textColor="#884444"
                        style="@style/Widget.MaterialComponents.Button"/>

                </LinearLayout>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ── LC02H Baseline Calibration ── -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#080F1E" app:cardCornerRadius="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="LC02H ANTENNA BASELINE" android:textColor="#55CCFF"
                    android:textSize="13sp" android:textStyle="bold"
                    android:fontFamily="monospace" android:layout_marginBottom="4dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Keep boat perfectly still at dock. Measures the true effective antenna separation so you can update the LC02H config."
                    android:textColor="#88AABBCC" android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <!-- Measured baseline input row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Measured baseline (m):"
                        android:textColor="#88AABBCC" android:textSize="12sp"
                        android:fontFamily="monospace"/>
                    <EditText android:id="@+id/etMeasuredBaseline"
                        android:layout_width="90dp" android:layout_height="40dp"
                        android:inputType="numberDecimal"
                        android:text="1.000"
                        android:textColor="#14FFEC" android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:textAlignment="center"
                        android:background="@android:color/transparent"
                        android:paddingHorizontal="4dp"/>
                </LinearLayout>

                <TextView android:id="@+id/tvBaselineCalStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Tap START to calibrate"
                    android:textColor="#55CCFF" android:textSize="12sp"
                    android:fontFamily="monospace" android:layout_marginBottom="4dp"/>

                <TextView android:id="@+id/tvBaselineCalSaved"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Not calibrated — using measured baseline"
                    android:textColor="#55AABBCC" android:textSize="11sp"
                    android:fontFamily="monospace" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btnBaselineCalStart"
                        android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:text="▶ START (60s)"
                        android:textSize="13sp" android:textStyle="bold"
                        android:backgroundTint="#0D1A2E" android:textColor="#55CCFF"
                        android:layout_marginEnd="6dp"
                        style="@style/Widget.MaterialComponents.Button"/>
                    <Button android:id="@+id/btnBaselineCalClear"
                        android:layout_width="wrap_content" android:layout_height="44dp"
                        android:text="CLR" android:textSize="11sp"
                        android:backgroundTint="#1A0A0A" android:textColor="#884444"
                        style="@style/Widget.MaterialComponents.Button"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Notes -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="• Mag cal: rotate once at dock. Redo if metal moves near sensor.\n• Gyro cal: redo if temperature changes significantly.\n• GPS auto-cal runs automatically at sea (speed>2kt, calm).\n• Disconnect after calibration — motor control uses a separate connection."
            android:textColor="#44AABBCC" android:textSize="11sp"
            android:fontFamily="monospace" android:lineSpacingExtra="4dp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</ScrollView>